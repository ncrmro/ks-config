#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: k8s-apply-secrets [--dry-run]

Decrypt Ocean's agenix-managed Kubernetes Secret manifests and apply them
directly from memory. Plaintext manifests are never written to disk.
EOF
}

dry_run=false
case "${1:-}" in
  "") ;;
  --dry-run) dry_run=true ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
if (( $# > 1 )); then
  usage >&2
  exit 2
fi

: "${DEVENV_ROOT:?Run k8s-apply-secrets from the repository devenv}"
export KUBECONFIG="${KUBECONFIG:-$HOME/.kube/config.ocean.yml}"
expected_server="${K8S_EXPECTED_SERVER:-https://100.64.0.6:6443}"
field_manager="k8s-cluster-secrets"

if [[ ! -r "$KUBECONFIG" ]]; then
  echo "k8s-apply-secrets: kubeconfig is not readable: $KUBECONFIG" >&2
  exit 1
fi
actual_server="$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}')"
if [[ "$actual_server" != "$expected_server" ]]; then
  echo "k8s-apply-secrets: refusing cluster server '$actual_server'; expected '$expected_server'" >&2
  exit 1
fi
kubectl get --raw=/readyz >/dev/null

resolve_secrets_dir() {
  local candidate
  for candidate in \
    "${AGENIX_SECRETS_DIR:-}" \
    "$DEVENV_ROOT/agenix-secrets" \
    "$HOME/repos/ncrmro/agenix-secrets" \
    "$HOME/.keystone/repos/ncrmro/agenix-secrets"; do
    if [[ -n "$candidate" && -f "$candidate/secrets.nix" && -d "$candidate/secrets" ]]; then
      (cd "$candidate" && pwd -P)
      return
    fi
  done
  echo "k8s-apply-secrets: cannot find a complete agenix-secrets checkout" >&2
  exit 1
}

secrets_dir="$(resolve_secrets_dir)"
secret_root="$secrets_dir/secrets/k8s/ocean"
if [[ ! -d "$secret_root" ]]; then
  echo "k8s-apply-secrets: secret manifest directory does not exist: $secret_root" >&2
  exit 1
fi

mapfile -t secret_files < <(find "$secret_root" -maxdepth 1 -type f -name '*.yaml.age' -print | sort)
if (( ${#secret_files[@]} == 0 )); then
  echo "k8s-apply-secrets: no encrypted Secret manifests found in $secret_root" >&2
  exit 1
fi

for secret_file in "${secret_files[@]}"; do
  relative_file="${secret_file#"$secrets_dir"/}"
  identity_args=()
  if [[ -n "${AGENIX_IDENTITY_FILE:-}" ]]; then
    identity_args=(-i "$AGENIX_IDENTITY_FILE")
  fi
  plaintext="$(cd "$secrets_dir" && agenix -d "$relative_file" "${identity_args[@]}")"

  mapfile -t kinds < <(printf '%s\n' "$plaintext" | yq eval-all -N -r '.kind // ""' -)
  if (( ${#kinds[@]} == 0 )); then
    echo "k8s-apply-secrets: decrypted file has no YAML documents: $relative_file" >&2
    exit 1
  fi
  for kind in "${kinds[@]}"; do
    if [[ "$kind" != "Secret" ]]; then
      echo "k8s-apply-secrets: refusing non-Secret kind '$kind' in $relative_file" >&2
      exit 1
    fi
  done

  # This command is the authoritative writer for encrypted Secret manifests,
  # including credentials that predate this workflow.
  apply_args=(apply --server-side --force-conflicts --field-manager="$field_manager")
  if [[ "$dry_run" == true ]]; then
    apply_args+=(--dry-run=server)
  fi
  printf '%s\n' "$plaintext" | kubectl "${apply_args[@]}" -f -
  unset plaintext
done
