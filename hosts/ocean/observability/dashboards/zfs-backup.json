{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Backup Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "FAIL", "color": "red" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last Success" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Age" },
            "properties": [
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Status", "desc": true }]
      },
      "targets": [
        {
          "expr": "zfs_backup_last_exit_code",
          "format": "table",
          "instant": true,
          "refId": "exit_code"
        },
        {
          "expr": "zfs_backup_last_success_timestamp",
          "format": "table",
          "instant": true,
          "refId": "last_success"
        },
        {
          "expr": "time() - zfs_backup_last_success_timestamp",
          "format": "table",
          "instant": true,
          "refId": "age"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "job": "Job",
              "source_host": "Source Host",
              "source_pool": "Source Pool",
              "target_host": "Target Host",
              "target_pool": "Target Pool",
              "Value #exit_code": "Status",
              "Value #last_success": "Last Success",
              "Value #age": "Age"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true
            }
          }
        }
      ]
    },
    {
      "title": "Snapshot Age by Host/Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 7200 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "zfs_snapshot_newest_age_seconds{host=~\"$host\"}",
          "legendFormat": "{{ host }}:{{ pool }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Snapshot Count by Host/Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "zfs_snapshot_count{host=~\"$host\"}",
          "legendFormat": "{{ host }}:{{ pool }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Replication Duration Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "changes(zfs_backup_last_success_timestamp{job=~\"$job\"}[1h]) > 0",
          "legendFormat": "{{ job }} (completed)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Pool Usage",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "max": 1,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "zfs_pool_allocated_bytes / zfs_pool_size_bytes",
          "legendFormat": "{{ instance }} - {{ pool }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["zfs", "backup"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(zfs_snapshot_newest_age_seconds, host)",
        "includeAll": true,
        "multi": true,
        "name": "host",
        "query": "label_values(zfs_snapshot_newest_age_seconds, host)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(zfs_backup_last_exit_code, job)",
        "includeAll": true,
        "multi": true,
        "name": "job",
        "query": "label_values(zfs_backup_last_exit_code, job)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "ZFS Backup Overview",
  "uid": "zfs-backup-overview"
}
